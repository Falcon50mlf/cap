{
  "extends": ["next/core-web-vitals", "next/typescript", "prettier"],
  "rules": {
    "react/jsx-no-comment-textnodes": "off",
    "@typescript-eslint/no-unused-vars": "error",
    "@typescript-eslint/no-explicit-any": "warn",
    "react-hooks/exhaustive-deps": "warn",
    "prefer-const": "error"
  }
}
